{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remind Me",
  "version": "1.3.0",
  "identifier": "com.moses.remindme",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Remind Me",
        "width": 410,
        "height": 540,
        "minWidth": 360,
        "minHeight": 440,
        "center": true,
        "resizable": true,
        "skipTaskbar": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "Fishcake Software",
    "shortDescription": "A compact tray reminder that is ready in one shortcut.",
    "longDescription": "Press Ctrl+Alt+R, type a reminder, then drag it onto the next 90 minutes. Everything stays local and reminders use native Windows notifications.",
    "category": "Productivity",
    "copyright": "Copyright © 2026 Fishcake Software",
    "resources": {
      "resources/sounds/gentle.wav": "sounds/gentle.wav",
      "resources/sounds/bell.wav": "sounds/bell.wav",
      "resources/sounds/chime.wav": "sounds/chime.wav"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGQzAzRTlDMDU2QTM4MTQKUldRVU9Hb0ZuRDdBYnpQOXhweURQUEl3ZnpHRDRMaXFNY0RaZmppSmhMdXZPZ2xTWmxadGp6KzAK",
      "endpoints": [
        "https://github.com/fishcake-coder/remind-me/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
